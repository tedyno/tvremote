# Copy to .env and fill in for your TV.
TV_IP=192.168.1.10              # TV IP address (required)
TV_MAC=AA:BB:CC:DD:EE:FF        # TV MAC for Wake-on-LAN (optional; without it the TV can't be powered on)
TV_PORT=8002                    # WebSocket port (Samsung: 8002)
SERVER_PORT=3000                # port this server listens on
APP_NAME=TVRemote               # name shown when pairing with the TV
TOKEN_FILE=./data/tv-token.txt  # where to store the pairing token
